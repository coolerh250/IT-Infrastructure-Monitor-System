# Copy this file to .env and replace placeholder values before deployment.
# Do not commit .env or any file containing real passwords, tokens, PATs, or SMTP credentials.

COMPOSE_PROJECT_NAME=it-monitor
TZ=Asia/Taipei

# Management source network. Override per site as needed.
MANAGEMENT_CIDR=10.0.1.0/24

# Published service ports.
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090
ALERTMANAGER_PORT=9093

# Grafana and PostgreSQL.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD_FILE=./secrets/grafana_admin_password
POSTGRES_DB=grafana
POSTGRES_USER=grafana
POSTGRES_PASSWORD_FILE=./secrets/postgres_password

# Email alerting. Keep the recipient template and replace SMTP settings locally.
ALERT_EMAIL_TO=admin@example.com
ALERT_EMAIL_FROM=monitoring@example.com
SMTP_SMARTHOST=smtp.example.com:587
SMTP_USERNAME=monitoring@example.com
SMTP_PASSWORD_FILE=./secrets/smtp_password
SMTP_REQUIRE_TLS=true

# Backup settings.
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=14
BACKUP_PASSPHRASE_FILE=./secrets/backup_passphrase

# Optional image tags.
PROMETHEUS_IMAGE=prom/prometheus:v2.54.1
GRAFANA_IMAGE=grafana/grafana:11.2.2
POSTGRES_IMAGE=postgres:16-alpine
ALERTMANAGER_IMAGE=prom/alertmanager:v0.27.0
BLACKBOX_IMAGE=prom/blackbox-exporter:v0.25.0
NODE_EXPORTER_IMAGE=prom/node-exporter:v1.8.2
